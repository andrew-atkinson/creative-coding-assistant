# Copy to .env and fill in real values. Never commit .env.

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# --- LLM (OpenAI-compatible endpoint) ---
# Local dev (LM Studio):
#   LLM_BASE_URL=http://localhost:1234/v1
#   LLM_API_KEY=lmstudio
#   LLM_MODEL=<the model id shown in LM Studio, e.g. unsloth-gemma-4-26b-a4b-it-qat-oq4>
# Hosted (Groq free tier):
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_API_KEY=gsk_...
#   LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lmstudio
LLM_MODEL=
# Optional: separate (usually smaller) model for the routing pass.
# Falls back to LLM_MODEL when empty.
LLM_ROUTER_MODEL=

# --- M1 admin auth (shared secret; swapped for Supabase JWT in M2) ---
ADMIN_SECRET=

# --- Runtime origin (used for CORS + client links). Config-driven, not hardcoded. ---
PUBLIC_RUNTIME_ORIGIN=http://localhost:5173
